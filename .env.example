# Application
APP_NAME=FinSight AI Platform
APP_ENV=local
DEBUG=true
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Security
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg2://finsight:finsight@postgres:5432/finsight

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Object Storage
STORAGE_PROVIDER=minio
S3_BUCKET_NAME=finsight-documents
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://minio:9000

# Vector DB
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=finsight_documents

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Optional
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# RAG
RAG_TOP_K=10
RAG_RERANK_TOP_K=5
RAG_MIN_SIMILARITY_SCORE=0.72

# Guardrails
REQUIRE_CITATIONS=true
BLOCK_INVESTMENT_ADVICE=true
ENABLE_PROMPT_INJECTION_CHECK=true
ENABLE_PII_REDACTION=true

# Evaluation
ENABLE_EVALUATIONS=true
MIN_FAITHFULNESS_SCORE=0.85
MIN_CITATION_ACCURACY=0.90

# Observability
ENABLE_OTEL=true
OTEL_SERVICE_NAME=finsight-api
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO

# Email / Notification
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Slack
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL=